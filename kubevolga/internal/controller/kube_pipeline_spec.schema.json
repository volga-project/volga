{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KubePipelineSpec",
  "type": "object",
  "properties": {
    "event_time": {
      "$ref": "#/$defs/EventTimeSpec",
      "default": {
        "watermark": {
          "idle_timeout_ms": null,
          "out_of_orderness_ms": 0
        },
        "window": {
          "allowed_lateness_ms": null
        }
      }
    },
    "execution_mode": {
      "$ref": "#/$defs/ExecutionMode",
      "default": "Streaming"
    },
    "execution_profile": {
      "anyOf": [
        {
          "$ref": "#/$defs/ExecutionProfile"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "operator_overrides": {
      "default": {
        "defaults": {
          "transport": null,
          "tuning": null
        },
        "per_operator": {}
      }
    },
    "operator_type_storage": {
      "default": {}
    },
    "parallelism": {
      "type": "integer",
      "format": "uint",
      "default": 1,
      "minimum": 0
    },
    "request_source_sink": {
      "default": null
    },
    "sink": {
      "default": null
    },
    "sources": {
      "default": []
    },
    "sql": {
      "type": [
        "string",
        "null"
      ],
      "default": null
    },
    "task_assignment_strategy": {
      "anyOf": [
        {
          "$ref": "#/$defs/TaskWorkerAssignmentStrategyType"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "worker_runtime": {
      "default": {
        "history_retention_window_ms": null,
        "window_state_namespace": "window_state",
        "transport": {
          "default_queue_records": 8192
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "EventTimeSpec": {
      "description": "Pipeline-wide event-time defaults (SQL / streaming).\n\nWatermark knobs are shared; allowed lateness is namespaced by operator kind\n(`window` now; `join` later) so semantics stay distinct.",
      "type": "object",
      "properties": {
        "watermark": {
          "$ref": "#/$defs/WatermarkSpec",
          "default": {
            "idle_timeout_ms": null,
            "out_of_orderness_ms": 0
          }
        },
        "window": {
          "$ref": "#/$defs/WindowEventTimeSpec",
          "default": {
            "allowed_lateness_ms": null
          }
        }
      }
    },
    "ExecutionMode": {
      "type": "string",
      "enum": [
        "Request",
        "Streaming",
        "Batch"
      ]
    },
    "ExecutionProfile": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "SingleWorker": {
              "type": "object",
              "properties": {
                "num_threads_per_task": {
                  "type": "integer",
                  "format": "uint",
                  "minimum": 0
                }
              },
              "required": [
                "num_threads_per_task"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "SingleWorker"
          ]
        },
        {
          "type": "object",
          "properties": {
            "MasterWorker": {
              "type": "object",
              "properties": {
                "num_threads_per_task": {
                  "type": "integer",
                  "format": "uint",
                  "minimum": 0
                }
              },
              "required": [
                "num_threads_per_task"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "MasterWorker"
          ]
        }
      ]
    },
    "TaskWorkerAssignmentStrategyType": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "SingleWorker",
            "OperatorPerWorker"
          ]
        },
        {
          "description": "Flink-like slot scheduling: each task-index slice across all operators\nis placed into one slot on one worker; `slots_per_node` controls slices per worker.",
          "type": "object",
          "properties": {
            "Pipelined": {
              "type": "object",
              "properties": {
                "slots_per_node": {
                  "type": "integer",
                  "format": "uint",
                  "minimum": 0
                }
              },
              "required": [
                "slots_per_node"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "Pipelined"
          ]
        }
      ]
    },
    "WatermarkSpec": {
      "type": "object",
      "properties": {
        "idle_timeout_ms": {
          "description": "If set, idle upstreams older than this are excluded from min-WM merge.\n`None` keeps the runtime assigner default (`WatermarkAssignConfig::DEFAULT_IDLE_TIMEOUT_MS`).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 0
        },
        "out_of_orderness_ms": {
          "description": "Max event-time reorder delay for auto-placed watermark assigners (ms).",
          "type": "integer",
          "format": "uint64",
          "default": 0,
          "minimum": 0
        }
      }
    },
    "WindowEventTimeSpec": {
      "type": "object",
      "properties": {
        "allowed_lateness_ms": {
          "description": "Allowed lateness for window operators (ms). `None` = no lateness.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int64",
          "default": null
        }
      }
    }
  }
}